generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String        @id @default(cuid())
  name                String
  email               String        @unique
  password            String
  role                Role          @default(AGENT)
  createdAt           DateTime      @default(now())
  agentStatus         AgentStatus   @default(PENDING)
  forcePasswordChange Boolean       @default(false)
  fields              Field[]       @relation("AgentFields")
  observations        Observation[]
  accounts            Account[]
  sessions            Session[]
}

model Field {
  id           String        @id @default(cuid())
  name         String
  cropType     String
  plantingDate DateTime
  currentStage Stage
  status       Status        @default(Active)
  agentId      String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  agent        User?         @relation("AgentFields", fields: [agentId], references: [id])
  observations Observation[]
}

model Observation {
  id            String   @id @default(cuid())
  fieldId       String
  stage         Stage
  note          String
  agentId       String?
  createdAt     DateTime @default(now())
  aiRating      Int?
  cropHealth    String?
  soilCondition String?
  agent         User?    @relation(fields: [agentId], references: [id])
  field         Field    @relation(fields: [fieldId], references: [id])
}

model CropRule {
  id        String   @id @default(cuid())
  cropType  String
  stage     Stage
  minDays   Int
  maxDays   Int
  createdAt DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id])

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

model AdminInvite {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String?
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  AGENT
}

enum AgentStatus {
  PENDING
  ACTIVE
  FORMER
}

enum Stage {
  Planted
  Growing
  Ready
  Harvested
}

enum Status {
  Active
  AtRisk
  Completed
}
